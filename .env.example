# Shishya — environment variables
# Copy to .env.local and fill in real values. Never commit .env.local.

# Database (Postgres — Neon, Supabase, or Railway)
DATABASE_URL="postgresql://user:password@host:5432/shishya?sslmode=require"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"

# Google OAuth (Gmail social sign-in)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Anthropic Claude API
ANTHROPIC_API_KEY=""
ANTHROPIC_MODEL="claude-sonnet-4-5-20250929"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="Shishya"

# Admin — comma-separated emails that get access to /admin/* (SME validation)
ADMIN_EMAILS="venumuvva@gmail.com"
