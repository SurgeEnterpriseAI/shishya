# Shishya — environment variables
# Copy to .env.local and fill in real values. Never commit .env.local.

# ── Database (Postgres — Neon recommended) ─────────────────────────────
#
# Production: use the POOLED (pgBouncer) Neon endpoint for runtime so each
# serverless function holds ≤1 connection. The hostname includes "-pooler".
# At 10k concurrent students this is mandatory — the direct endpoint will
# exhaust Neon's pool within seconds.
#
# Required URL params for the pooled endpoint:
#   pgbouncer=true       — Prisma skips prepared statements (pgBouncer rejects them)
#   connection_limit=1   — one Postgres connection per Lambda instance
#
# Example pooled URL:
#   postgresql://USER:PASS@ep-xxx-pooler.<region>.aws.neon.tech/db?sslmode=require&pgbouncer=true&connection_limit=1
DATABASE_URL="postgresql://user:password@host-pooler.region.aws.neon.tech:5432/shishya?sslmode=require&pgbouncer=true&connection_limit=1"

# Direct (non-pooled) URL — needed only by `prisma migrate` / `db push`
# because pgBouncer's transaction-pool mode breaks the migration workflow.
# Drop the "-pooler" from the host and remove the pgbouncer/connection_limit params.
DIRECT_URL="postgresql://user:password@host.region.aws.neon.tech:5432/shishya?sslmode=require"

# ── NextAuth ────────────────────────────────────────────────────────────
# Sessions are JWT (stateless) so this secret signs the tokens — set it
# in Vercel env vars and rotate periodically.
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"

# ── Google OAuth (Gmail social sign-in) ─────────────────────────────────
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ── Anthropic Claude API ────────────────────────────────────────────────
ANTHROPIC_API_KEY=""
ANTHROPIC_MODEL="claude-sonnet-4-5-20250929"

# ── App ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="Shishya"

# ── Admin ───────────────────────────────────────────────────────────────
# Comma-separated emails that get access to /admin/*:
#   /admin            — content / SME validation hub
#   /admin/insights   — Shishya monitoring (growth, engagement, AI cost,
#                       funnel, top exams, recent activity, content health)
#   /admin/analytics  — first-party event analytics dashboard
# Add operator emails here, no DB change required. The user signs in via
# Google with one of these emails and the admin routes unlock automatically.
ADMIN_EMAILS="venumuvva@gmail.com,adminshishya@gmail.com"

# ── Search engine verification ──────────────────────────────────────────
# Drop the verification tokens here once you've added the property in
# Google Search Console / Bing Webmaster Tools. The metadata.verification
# block in src/app/layout.tsx reads these and emits the <meta> tags on
# every page — once the token is live, click "Verify" in the consoles.
#
# How to get the values:
#   GOOGLE: https://search.google.com/search-console → Add property →
#           pick "HTML tag" → copy the content="..." value
#   BING:   https://www.bing.com/webmasters → Add site → HTML tag method
GOOGLE_SITE_VERIFICATION=""
BING_SITE_VERIFICATION=""

# ── Rate limiting (Upstash Redis, REST) ─────────────────────────────────
# Optional in dev (falls back to an in-memory limiter — sufficient for a
# single instance). MANDATORY in production: without these, each serverless
# Lambda has its own private counter and the per-user quota is meaningless.
# Free tier at https://upstash.com is enough for <100k req/day.
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# ── Cron ────────────────────────────────────────────────────────────────
# Used by /api/cron/daily-brief. Vercel Cron sends "Authorization: Bearer ${CRON_SECRET}".
CRON_SECRET=""

# ── Domain AI system ──────────────────────────────────────────────────────
# Model router tiers (optional — sensible defaults in src/lib/ai/router.ts)
# ANTHROPIC_MODEL_FAST=claude-haiku-4-5-20251001
# ANTHROPIC_MODEL_STRONG=claude-opus-4-8

# Knowledge spine (RAG) — Voyage AI embeddings (https://dash.voyageai.com/)
# Required for npm run kb:ingest and the tutor search_knowledge tool.
# VOYAGE_API_KEY=
# VOYAGE_MODEL=voyage-3
