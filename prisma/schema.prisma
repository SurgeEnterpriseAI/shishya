// Shishya — Free, community-driven Indian education platform
// Database schema for users, exams, syllabus, questions, mocks, attempts, community verifications, AI assistance.

generator client {
  provider      = "prisma-client-js"
  // "native" is the local-dev target (Windows on this machine); the rhel target
  // is what Vercel's build/serverless runtime uses on Linux.
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  // Runtime traffic uses the pooled (pgBouncer) Neon endpoint so a single
  // serverless function holds at most one Postgres connection. Without this,
  // 10k concurrent serverless invocations would each open direct sockets
  // and exhaust Neon's pool.
  url       = env("DATABASE_URL")
  // Prisma needs a direct (non-pooled) URL for `prisma migrate` / `db push`
  // because pgBouncer rejects the prepared-statement workflow they use.
  directUrl = env("DIRECT_URL")
}

// ─────────────────────────────────────────────────────────────────────────
// AUTH (NextAuth-compatible)
// ─────────────────────────────────────────────────────────────────────────

model User {
  id                      String     @id @default(cuid())
  email                   String     @unique
  emailVerified           DateTime?
  name                    String?
  image                   String?
  preferredLang           Language   @default(EN)
  // First-time onboarding tour completion timestamp. Null = the user has
  // never finished the dashboard tour; <OnboardingTour /> auto-mounts in
  // that case. Set to NOW() on "Done" or "Skip" so it never re-appears.
  onboardedAt             DateTime?
  // Attribution: captured once on first signed-in page load from a
  // cookie set on /login. Tells us where this user came from when no
  // UTM params were on the URL (organic, Reddit, Telegram, etc.)
  // referrerUrl  = full Referer header (or stored UTM URL fragment)
  // referrerHost = parsed hostname for cheap GROUP BY queries
  signupReferrerUrl       String?
  signupReferrerHost      String?
  // Verification-system contribution tracking. All default to 0 so the
  // migration is non-breaking — existing users land as NEWCOMER with
  // zero counts. Counts are incremented by the verification flow,
  // resetting only on admin override (e.g., when a flag is invalidated
  // we DECREMENT flagValidatedCount).
  contributionScore       Int        @default(0)
  verificationCount       Int        @default(0)
  flagCount               Int        @default(0)
  flagValidatedCount      Int        @default(0)
  suggestionAcceptedCount Int        @default(0)
  badgeLevel              BadgeLevel @default(NEWCOMER)
  badgeEarnedAt           DateTime?
  // [{ type: "exam_cleared" | "currently_at" | "working_at", domain: "UPSC", verifiedAt: ISO, source: "linkedin" | "doc" | "vouching" | "email" }]
  domainExpertCredentials Json?
  // Public-profile opt-in. When TRUE + `handle` is non-null, the user's
  // contribution profile is exposed at /u/[handle] for SEO + recognition.
  // Default FALSE — users must opt in explicitly (no dark pattern of
  // public-by-default).
  profilePublic           Boolean    @default(false)
  // URL handle for /u/[handle]. Unique across the platform. Null until
  // the user picks one in /me/settings. Validated to ^[a-z0-9_-]{3,30}$.
  handle                  String?    @unique
  // Onboarding-wizard answers — captured the first time a user signs in
  // and answers the 3-question profile form. Drives the personalised
  // homepage (their stage's content + state's scholarships + prep targets).
  // Null until completed; the wizard at /onboarding sets all three.
  onbStage                String? // "CLASS_9_10" | "CLASS_11_12" | "UG" | "PG" | "WORKING"
  onbState                String? // ISO 2-letter Indian state code, e.g., "MH", "TN"
  onbPrepCodes            String[]   @default([]) // exam codes the user is targeting
  onbCompletedAt          DateTime? // set when wizard is submitted (different from onboardedAt which is the dashboard tour)
  createdAt               DateTime   @default(now())
  updatedAt               DateTime   @updatedAt

  accounts           Account[]
  sessions           Session[]
  enrollments        Enrollment[]
  mocks              Mock[]
  attempts           Attempt[]
  weaknessMaps       WeaknessMap[]
  chatSessions       ChatSession[]
  progressEvents     ProgressEvent[]
  discussions        Discussion[]           @relation("DiscussionAuthor")
  discussionMessages DiscussionMessage[]    @relation("MessageAuthor")
  questionReports    QuestionReport[]
  featureRequests    FeatureRequest[]       @relation("FeatureRequestAuthor")
  featureUpvotes     FeatureRequestUpvote[] @relation("FeatureRequestVoter")
  dailyBriefs        DailyBrief[]
  verifications      Verification[]         @relation("UserVerifications")
  adminAudits        VerificationAudit[]    @relation("AdminAudits")
  credentials        UserCredential[]       @relation("UserCredentials")
  vouches            CredentialVouch[]      @relation("UserVouches")
  notifications      Notification[]         @relation("UserNotifications")
  batchEnrollments   BatchEnrollment[]

  @@index([email])
  @@index([badgeLevel])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─────────────────────────────────────────────────────────────────────────
// EXAMS & SYLLABUS
// ─────────────────────────────────────────────────────────────────────────

model Exam {
  id                String       @id @default(cuid())
  code              String       @unique // e.g. "SSC_CGL", "NEET_UG"
  name              String // "SSC CGL Tier 1"
  shortName         String // "SSC CGL"
  category          ExamCategory
  description       String       @db.Text
  durationMin       Int // exam duration in minutes
  totalQuestions    Int // total Qs in real exam
  totalMarks        Float
  marksPerQ         Float
  negativeMark      Float        @default(0)
  languages         Language[] // languages exam is offered in
  active            Boolean      @default(true)
  candidatesPerYear Int? // approximate annual volume
  // ISO state code for STATE_LEVEL exams (TN, KA, MH, UP, ...). Null for
  // national/central exams. Drives the StatePicker grouping.
  state             String?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  subjects       Subject[]
  questions      Question[]
  mocks          Mock[]
  enrollments    Enrollment[]
  weaknessMaps   WeaknessMap[]
  chatSessions   ChatSession[]
  discussions    Discussion[]
  newsItems      ExamNewsItem[]
  importantDates ExamImportantDate[]
  rankBands      ExamRankBand[]
  phaseArticles  ExamPhaseArticle[]
  reviewStates   ReviewState[]

  @@index([code])
  @@index([active])
  @@index([category, state])
}

model Subject {
  id        String   @id @default(cuid())
  examId    String
  code      String // e.g. "QUANT", "REASONING"
  name      String // "Quantitative Aptitude"
  weight    Float    @default(1) // relative weightage
  orderIdx  Int      @default(0)
  createdAt DateTime @default(now())

  exam   Exam    @relation(fields: [examId], references: [id], onDelete: Cascade)
  topics Topic[]

  @@unique([examId, code])
  @@index([examId])
}

model Topic {
  id               String    @id @default(cuid())
  subjectId        String
  parentId         String? // null for top-level topics; otherwise subtopic
  code             String // e.g. "quant.percentage"
  name             String
  description      String?   @db.Text
  syllabusText     String?   @db.Text // detailed syllabus content for AI context
  // Student-facing study material (markdown). Populated by
  // scripts/generate-topic-notes.ts. Sectioned: overview, key concepts,
  // formulas, worked examples, common mistakes, quick reference.
  notes            String?   @db.Text
  notesGeneratedAt DateTime?
  notesGeneratedBy String?
  // Human review of AI-generated notes (Crack Path Task 1). validatedAt
  // set = "validated"; null = "needs_review".
  notesValidatedAt DateTime?
  notesValidatedBy String?
  weight           Float     @default(1)
  orderIdx         Int       @default(0)
  createdAt        DateTime  @default(now())

  subject      Subject       @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  parent       Topic?        @relation("TopicTree", fields: [parentId], references: [id], onDelete: SetNull)
  children     Topic[]       @relation("TopicTree")
  questions    Question[]
  weaknessMaps WeaknessMap[]
  reviewStates ReviewState[]

  @@unique([subjectId, code])
  @@index([parentId])
}

// ─────────────────────────────────────────────────────────────────────────
// QUESTIONS
// ─────────────────────────────────────────────────────────────────────────

model Question {
  id          String         @id @default(cuid())
  examId      String
  topicId     String
  type        QuestionType   @default(MCQ)
  difficulty  Difficulty     @default(MEDIUM)
  body        String         @db.Text
  options     Json // [{ key: "A", text: "..." }, ...]
  answerKey   String // "A" | "B" | "C" | "D" — or comma-separated for multi-select
  solution    String         @db.Text
  hints       Json? // optional array of progressive hints
  language    Language       @default(EN)
  source      QuestionSource @default(SME)
  validated   Boolean        @default(false)
  validatedBy String?
  validatedAt DateTime?
  tags        String[]       @default([])
  pyqYear     Int? // previous-year-question year, if applicable
  metadata    Json? // freeform: estimated time, similar Qs, etc.
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  exam         Exam                  @relation(fields: [examId], references: [id], onDelete: Cascade)
  topic        Topic                 @relation(fields: [topicId], references: [id], onDelete: Cascade)
  reports      QuestionReport[]
  translations QuestionTranslation[]

  @@index([examId, topicId])
  @@index([difficulty])
  @@index([validated])
  @@index([language])
}

// Student-flagged questions. The student notices the answer key, the
// solution, the question body, or the options look wrong; they click
// "Report" on the per-question review and we capture their reason here.
// Admin reviews under /admin and fixes / removes the question.
model QuestionReport {
  id         String    @id @default(cuid())
  questionId String
  userId     String? // null when reported by a signed-out flow
  reason     String    @db.Text
  resolved   Boolean   @default(false)
  resolvedBy String?
  resolvedAt DateTime?
  createdAt  DateTime  @default(now())

  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  user     User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([questionId])
  @@index([resolved])
  @@index([createdAt])
}

// In-product feature requests. Students click a tiny floating pill on
// any page and tell us what feature they want; the request is auto-
// tagged with the route they were on and the area (Mock tests / Tutor /
// Translations / Results / UI / Other) so we can slice volume by where
// the friction lives. Public /ideas board lets others upvote.
model FeatureRequest {
  id          String               @id @default(cuid())
  // First-sentence derivation server-side; full text goes in body.
  title       String               @db.Text
  body        String               @db.Text
  // Auto-tagged page context
  routePath   String // e.g. /exams/SSC_CGL/topics/quant.percentage
  area        String // "Mock tests" | "AI Tutor" | "Translations" | "Results & Rank" | "UI / Navigation" | "Other"
  examCode    String? // populated when the route is exam-scoped
  // Author — null when signed-out flow (we still capture impulse ideas)
  authorId    String?
  authorName  String?
  authorEmail String?
  // Triage by admin
  status      FeatureRequestStatus @default(OPEN)
  adminNote   String?              @db.Text
  // Social proof — denormalised count, source of truth is FeatureRequestUpvote
  upvoteCount Int                  @default(0)
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  author  User?                  @relation("FeatureRequestAuthor", fields: [authorId], references: [id], onDelete: SetNull)
  upvotes FeatureRequestUpvote[]

  @@index([status, upvoteCount])
  @@index([area, createdAt])
  @@index([createdAt])
}

// One upvote per (requestId, userId). Anonymous upvoting isn't allowed
// because we want one-person-one-vote to prevent gaming the ideas board.
model FeatureRequestUpvote {
  id        String   @id @default(cuid())
  requestId String
  userId    String
  createdAt DateTime @default(now())

  request FeatureRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  user    User           @relation("FeatureRequestVoter", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([requestId, userId])
  @@index([userId])
}

// Question translations. A question authored in EN (or any base language)
// gets translated on-demand into the student's chosen locale and the result
// is cached here so the next student to pick the same language gets it
// instantly. Locale is a string (not the Language enum) so we can support
// every locale our i18n UI dictionary supports — including Sanskrit,
// Konkani, Manipuri, etc. that the user-facing Language enum doesn't list.
model QuestionTranslation {
  id         String   @id @default(cuid())
  questionId String
  locale     String // matches i18n.ts locale codes: "hi", "te", "ta", "bn", ...
  body       String   @db.Text
  options    Json // [{ key: "A", text: "<translated>" }, ...]
  solution   String   @db.Text
  hints      Json?
  // The model + prompt version that produced this translation. Lets us
  // re-translate if we change either later.
  generator  String?
  createdAt  DateTime @default(now())

  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([questionId, locale])
  @@index([locale])
}

// ─────────────────────────────────────────────────────────────────────────
// ENROLLMENTS — student joining an exam track
// ─────────────────────────────────────────────────────────────────────────

model Enrollment {
  id         String    @id @default(cuid())
  userId     String
  examId     String
  targetDate DateTime? // when the student plans to take the exam
  goalScore  Float?
  active     Boolean   @default(true)
  createdAt  DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  exam Exam @relation(fields: [examId], references: [id], onDelete: Cascade)

  @@unique([userId, examId])
  @@index([userId])
}

// ─────────────────────────────────────────────────────────────────────────
// MOCKS & ATTEMPTS
// ─────────────────────────────────────────────────────────────────────────

model Mock {
  id                String   @id @default(cuid())
  userId            String? // null for system templates available to all users
  examId            String
  type              MockType
  title             String
  config            Json // { topics: [...], difficultyMix: {...}, count, durationMin }
  questionIds       String[] // ordered list of Question.id
  generatedBy       String   @default("system") // "system" | "ai" | "ai:diagnostic" | "user-request"
  generationContext Json? // snapshot of student state at generation time
  createdAt         DateTime @default(now())

  user        User?        @relation(fields: [userId], references: [id], onDelete: Cascade)
  exam        Exam         @relation(fields: [examId], references: [id], onDelete: Cascade)
  attempts    Attempt[]
  dailyBriefs DailyBrief[]

  @@index([userId, examId])
  @@index([type])
}

model Attempt {
  id          String        @id @default(cuid())
  mockId      String
  userId      String
  status      AttemptStatus @default(IN_PROGRESS)
  startedAt   DateTime      @default(now())
  finishedAt  DateTime?
  durationSec Int?
  answers     Json // [{ questionId, chosen, correct, timeSec, marked }]
  scoreRaw    Float?
  scoreMax    Float?
  scorePct    Float?
  topicScores Json? // { topicId: { correct, total, score } }
  rank        Int?
  percentile  Float?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  mock Mock @relation(fields: [mockId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, mockId])
  @@index([status])
}

// ─────────────────────────────────────────────────────────────────────────
// AI STATE — weakness map, chat sessions, progress
// ─────────────────────────────────────────────────────────────────────────

model WeaknessMap {
  id            String   @id @default(cuid())
  userId        String
  examId        String
  topicId       String
  masteryScore  Float    @default(0) // 0.0 – 1.0
  attemptsCount Int      @default(0)
  correctCount  Int      @default(0)
  avgTimeSec    Float?
  lastSeenAt    DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  exam  Exam  @relation(fields: [examId], references: [id], onDelete: Cascade)
  topic Topic @relation(fields: [topicId], references: [id], onDelete: Cascade)

  @@unique([userId, examId, topicId])
  @@index([userId, examId])
}

model ChatSession {
  id              String   @id @default(cuid())
  userId          String
  examId          String?
  title           String?
  contextSnapshot Json? // student state at session start
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user     User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  exam     Exam?         @relation(fields: [examId], references: [id], onDelete: SetNull)
  messages ChatMessage[]

  @@index([userId])
}

model ChatMessage {
  id        String   @id @default(cuid())
  sessionId String
  role      ChatRole
  content   String   @db.Text
  toolCalls Json? // tool calls made by Claude in this turn
  metadata  Json? // tokens used, cache hits, latency
  createdAt DateTime @default(now())

  session ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, createdAt])
}

model ProgressEvent {
  id        String       @id @default(cuid())
  userId    String
  examId    String?
  type      ProgressType
  delta     Float? // numeric change (score, mastery, etc.)
  metadata  Json?
  createdAt DateTime     @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([type])
}

// Daily brief generated overnight by /api/cron/daily-brief.
// One row per (user, exam, calendar day) — uniqueness lets the cron be
// re-runnable safely. The dashboard's "Today's recommended mock" card
// reads the most-recent brief for each enrolled exam and shows the
// reflection + a deep-link to the pre-built adaptive mock.
model DailyBrief {
  id         String   @id @default(cuid())
  userId     String
  examId     String
  // Day this brief is for, normalised to 00:00 UTC. Lets us upsert by
  // (user, exam, day) and ensures one brief per calendar day.
  briefDate  DateTime @db.Date
  // 2–3 sentence reflection from Shishya: what the student worked on,
  // what to focus on today, why. Markdown allowed but kept short.
  reflection String   @db.Text
  // Pointer to the pre-generated adaptive mock for the student to take.
  // Nullable so reflection-only briefs (e.g. mock-pool too thin) still work.
  mockId     String?
  // Snapshot of the inputs used (mastery weakest topics, top asked-about
  // topics) — handy for debugging cron output.
  inputs     Json?
  createdAt  DateTime @default(now())

  user User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  mock Mock? @relation(fields: [mockId], references: [id], onDelete: SetNull)

  @@unique([userId, examId, briefDate])
  @@index([userId, briefDate])
}

// ─────────────────────────────────────────────────────────────────────────
// COMMUNITY — discussion threads & messages (visible on home page)
// ─────────────────────────────────────────────────────────────────────────

model Discussion {
  id             String   @id @default(cuid())
  title          String
  // Optional exam scope. When non-null, the discussion appears on that exam's
  // page in addition to the global discussions list.
  examId         String?
  // Author at thread creation. Display name is denormalised so list views
  // don't have to JOIN to render.
  authorId       String?
  authorName     String?
  // Denormalised counters / activity timestamp keep the home-page list cheap.
  lastActivityAt DateTime @default(now())
  messageCount   Int      @default(0)
  locked         Boolean  @default(false)
  // Sticky / pinned threads bubble to the top of the home list.
  pinned         Boolean  @default(false)
  // True when the row was AI-generated by /api/cron/refresh-discussions
  // to seed the right-rail with plausible activity for a freshly-
  // upcoming exam that has no real threads yet. The UI labels these
  // as "sample" so visitors know they're starter content, not
  // actual student posts. Seed rows are pruned and re-generated on
  // every cron tick; real (user-created) threads are never touched.
  isSeed         Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  exam     Exam?               @relation(fields: [examId], references: [id], onDelete: SetNull)
  author   User?               @relation("DiscussionAuthor", fields: [authorId], references: [id], onDelete: SetNull)
  messages DiscussionMessage[]

  @@index([lastActivityAt])
  @@index([examId])
  @@index([pinned, lastActivityAt])
}

model DiscussionMessage {
  id         String   @id @default(cuid())
  threadId   String
  authorId   String?
  authorName String?
  content    String   @db.Text
  createdAt  DateTime @default(now())

  thread Discussion @relation(fields: [threadId], references: [id], onDelete: Cascade)
  author User?      @relation("MessageAuthor", fields: [authorId], references: [id], onDelete: SetNull)

  @@index([threadId, createdAt])
}

// ─────────────────────────────────────────────────────────────────────────
// EXAM TIMELINE — news items & important dates per exam
// ─────────────────────────────────────────────────────────────────────────

model ExamNewsItem {
  id          String    @id @default(cuid())
  examId      String
  title       String
  body        String    @db.Text
  source      String? // optional URL to official notice / news source
  publishedAt DateTime  @default(now())
  createdAt   DateTime  @default(now())
  // Soft-delete marker. The refresh-exam-data cron sets this on prior
  // generated rows instead of deleting them, so students can still
  // browse the historical news archive per exam. NULL = currently
  // active and shown on the per-exam page. Non-null = archived but
  // surfaced behind a "Show older updates" toggle.
  archivedAt  DateTime?

  exam Exam @relation(fields: [examId], references: [id], onDelete: Cascade)

  @@index([examId, publishedAt])
  @@index([examId, archivedAt])
}

model ExamImportantDate {
  id         String    @id @default(cuid())
  examId     String
  label      String // e.g. "Application opens", "Tier 1 exam date"
  date       DateTime
  isExamDay  Boolean   @default(false) // highlight in UI
  source     String? // optional URL
  notes      String?   @db.Text
  createdAt  DateTime  @default(now())
  // Soft-delete marker. Same semantics as ExamNewsItem.archivedAt —
  // refresh-exam-data archives prior generated rows rather than
  // deleting them, preserving the timeline history for students.
  archivedAt DateTime?

  exam Exam @relation(fields: [examId], references: [id], onDelete: Cascade)

  @@index([examId, date])
  @@index([examId, archivedAt])
}

// ─────────────────────────────────────────────────────────────────────────
// EXAM PHASE ARTICLES — time-sensitive content that swaps automatically
// as the exam approaches and passes:
//
//   CHECKLIST  (T-7 to T-1)  — last-minute revision, must-know topics,
//                              what to carry to the exam centre
//   LIVE       (T-0)         — exam day: difficulty so far, shift-by-
//                              shift analysis, leaked answer keys
//   REACTIONS  (T+1 to T+3)  — student verdict, expected cutoff,
//                              official key analysis, "what did you
//                              think of Q34?" threads
//
// A 2-hour cron (Stage 2) scrapes free public sources — Reddit, RSS
// feeds, YouTube, public Telegram channels — feeds them through Claude
// to extract structured signal, and rewrites the article body. The
// `sourcesScraped` JSON keeps the citation trail so claims stay
// verifiable.
//
// The (examId, phase) tuple is unique: each exam has at most one
// active article per phase. Re-running the scraper updates the row
// in-place rather than creating duplicates.
// ─────────────────────────────────────────────────────────────────────────

model ExamPhaseArticle {
  id             String    @id @default(cuid())
  examId         String
  phase          ExamPhase
  // Slug suffix used in the public URL: /exams/{CODE}/{slug}. Almost
  // always matches the phase ("checklist" / "live" / "reactions") —
  // breaking it out as its own column lets us A/B test alt slugs for
  // SEO without a migration.
  slug           String
  title          String
  // 1-2 sentence preview shown in the sidebar / sidebar chip / OG
  // card — the value-prop hook before a student clicks through.
  // Should be ≤ 200 chars, plain text (no markdown), conversational.
  // Example for UPSC reactions:
  //   "Moderate-tough paper. Polity-heavy. Fewer current affairs
  //    than usual — early cutoff prediction: 88-94 (Gen)."
  summarySnippet String?
  // Markdown body. AI-generated + verified — rendered server-side so
  // we can safely interpolate Q&A blocks without exposing raw HTML
  // from the model.
  bodyMarkdown   String    @db.Text
  // Where the body's facts came from. JSON array of
  // { url, type: "reddit"|"rss"|"telegram"|"youtube"|"news"|"manual",
  //   scrapedAt: ISO, weight: 1-5 } so the article can show "Sources
  // we read" footers and reviewers can audit.
  sourcesScraped Json      @default("[]")
  // When the cron last rewrote the body. Drives the "Updated X min
  // ago" badge — critical for student trust on time-sensitive
  // post-exam content.
  lastUpdatedAt  DateTime  @default(now())
  // When the cron last attempted a scrape (may not have changed the
  // body if nothing new was found). Used by the scheduler to decide
  // when to re-run.
  lastScrapedAt  DateTime?
  viewCount      Int       @default(0)
  // Soft-delete / versioning marker. The refresh-phase-articles cron
  // used to OVERWRITE the article for a given (examId, phase) in place,
  // losing every prior cycle's write-up. Now it archives the active
  // version (sets archivedAt = now) and creates a fresh active row, so
  // each (CHECKLIST / LIVE / REACTIONS) cycle stays browsable as
  // "previous updates" on the phase page. NULL = the current/live
  // version shown by default; non-null = an archived earlier version.
  //
  // NOTE the (examId, phase) UNIQUE was dropped — multiple archived
  // rows + one active row now coexist per (examId, phase). Reads pick
  // the active one via `archivedAt: null` + most-recent ordering.
  archivedAt     DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  exam      Exam                  @relation(fields: [examId], references: [id], onDelete: Cascade)
  reactions ExamArticleReaction[]
  shares    ExamArticleShare[]

  @@index([examId, phase, archivedAt])
  @@index([examId])
  @@index([lastUpdatedAt])
}

model ExamArticleReaction {
  id        String          @id @default(cuid())
  articleId String
  // Identity. Anonymous users vote via the existing 30-day anonId
  // cookie; signed-in users vote with userId (and we collapse the
  // anon vote into theirs on next visit).
  userId    String?
  anonId    String?
  reaction  ArticleReaction
  createdAt DateTime        @default(now())

  article ExamPhaseArticle @relation(fields: [articleId], references: [id], onDelete: Cascade)

  // One vote per identity per article. Re-voting upserts.
  @@unique([articleId, userId])
  @@unique([articleId, anonId])
  @@index([articleId])
}

model ExamArticleShare {
  id        String       @id @default(cuid())
  articleId String
  channel   ShareChannel
  anonId    String?
  userId    String?
  createdAt DateTime     @default(now())

  article ExamPhaseArticle @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@index([articleId, channel])
}

enum ExamPhase {
  CHECKLIST
  LIVE
  REACTIONS
}

enum ArticleReaction {
  LIKE
  DISLIKE
}

enum ShareChannel {
  TWITTER
  WHATSAPP
  TELEGRAM
  LINKEDIN
  FACEBOOK
  COPY_LINK
}

// Rank prediction. Maps a student's mock-score band → expected real-exam
// rank band → likely outcome (which college / which posting they're
// realistically in contention for). Used by the post-attempt "Rank card"
// on the results page and the exam landing page's "What can I get?" panel.
//
// Bands are coarse on purpose: 5-8 tiers per exam is enough resolution for
// motivation and goal-setting; ultra-precise rank prediction is not the
// platform's job. AI-seeded for top exams from Claude's knowledge of recent
// cut-off trends; admin can override per exam.
model ExamRankBand {
  id          String    @id @default(cuid())
  examId      String
  // The score window (mock percentage) that maps to this band. Inclusive.
  scorePctMin Float
  scorePctMax Float
  // Expected real-exam rank window. May be null for non-rank exams
  // (e.g. SSC where outcome is "post + cadre" rather than numeric rank).
  rankMin     Int?
  rankMax     Int?
  // Short label, e.g. "Top 1%", "Tier 1 IITs likely", "Group A posts".
  label       String
  // Markdown bullet list of outcomes. e.g.:
  //   - AIIMS Delhi (last year cut-off ~50)
  //   - JIPMER Puducherry
  //   - Top state government medical colleges
  outcomes    String    @db.Text
  // Order in which to display (lowest scorePctMin first ⇒ orderIdx 0 highest).
  orderIdx    Int       @default(0)
  source      String? // "ai-generated:claude" or curated URL
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  // Soft-delete marker. refresh-rank-bands archives prior generated
  // rows instead of deleting them, so students can see how the
  // band/cutoff prediction has evolved over time. NULL = currently
  // active. Reads default to archivedAt IS NULL.
  archivedAt  DateTime?

  exam Exam @relation(fields: [examId], references: [id], onDelete: Cascade)

  @@index([examId, orderIdx])
  @@index([examId, archivedAt])
}

// ─────────────────────────────────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────────────────────────────────

enum FeatureRequestStatus {
  OPEN
  UNDER_REVIEW
  PLANNED
  SHIPPED
  DECLINED
}

enum Language {
  EN
  HI
  TE
  TA
  KN
  ML
  MR
  BN
  GU
  PA
}

enum ExamCategory {
  GOVT_JOBS // SSC, RRB
  BANKING // IBPS, SBI
  CIVIL_SERVICES // UPSC
  MEDICAL // NEET
  ENGINEERING // JEE, GATE
  TEACHING // CTET
  UNIVERSITY // CUET
  MBA // CAT
  LAW // CLAT
  OLYMPIAD // HBCSE, SOF, Silverzone, NSTSE, ZIO/INOI, PRIL
  STATE_LEVEL // State PSC, State TET, State Police, etc.
  // SCHOOL_BOARD entries are (Board, Class) units used as containers
  // for school-level Subject + Topic data — NOT real entrance exams.
  // The /exams catalog filters these out; they're surfaced under
  // /schooling/[board]/class-[n] instead. Lets us reuse the existing
  // Subject/Topic/Question/Mock pipeline for school content without
  // duplicating the schema.
  SCHOOL_BOARD
  OTHER
}

enum QuestionType {
  MCQ // single correct
  MSQ // multiple correct
  NUMERIC // type-the-number
  TRUE_FALSE
  MATCH // matching pairs
  COMPREHENSION // passage-based parent (children are MCQs)
}

enum Difficulty {
  EASY
  MEDIUM
  HARD
}

enum QuestionSource {
  SME // human subject-matter expert
  AI_GENERATED // generated by Claude, awaiting validation
  AI_VALIDATED // generated by Claude + reviewed by SME
  PYQ // previous year question (legally sourced)
  COMMUNITY // contributed by users
}

enum MockType {
  DIAGNOSTIC // first mock to map weaknesses
  FULL // mirrors real exam structure
  SUBJECT // single subject focus
  TOPIC // single topic drill
  ADAPTIVE // AI-generated based on weakness map
  REVISION // mistakes from past attempts
  CHALLENGE // harder than current level
  USER_REQUEST // user asked for specific config
}

enum AttemptStatus {
  IN_PROGRESS
  SUBMITTED
  ABANDONED
  AUTO_SUBMITTED
}

enum ChatRole {
  USER
  ASSISTANT
  SYSTEM
  TOOL
}

enum ProgressType {
  MOCK_COMPLETED
  TOPIC_MASTERED
  STREAK_DAY
  WEAKNESS_IMPROVED
  GOAL_REACHED
  RANK_CHANGE
}

// ─────────────────────────────────────────────────────────────────────────
// Verification system (Phase 2 of the trust-differentiator)
//
// One Fact row per verifiable claim across the platform. pageId is a
// polymorphic URL path ("/exams/jee-main", "/colleges/iit-madras") with
// a FactSection discriminator instead of 6 optional FKs. We trade
// referential integrity (a deleted Exam doesn't cascade-clean its Facts)
// for a single uniform Facts table — the spec treats facts as platform-
// wide objects, not per-entity rows.
// ─────────────────────────────────────────────────────────────────────────

model Fact {
  id                          String         @id @default(cuid())
  pageId                      String // canonical URL path, e.g. "/exams/jee-main"
  section                     FactSection // discriminator for the host page
  claimText                   String         @db.Text // human-readable: "NIRF Engineering rank"
  claimValue                  String         @db.Text // the actual value: "#1"
  sourceUrl                   String // official source URL
  sourceName                  String // "NIRF 2024", "CBSE", "NTA"
  originalIngestionDate       DateTime       @default(now())
  lastAiCheckDate             DateTime?
  lastAiCheckResult           AICheckResult?
  aiCheckCount                Int            @default(0)
  communityVerificationsCount Int            @default(0)
  trustedVerifierCount        Int            @default(0)
  domainExpertCount           Int            @default(0)
  flagCount                   Int            @default(0)
  status                      FactStatus     @default(NONE)
  createdAt                   DateTime       @default(now())
  updatedAt                   DateTime       @updatedAt

  verifications Verification[]
  audits        VerificationAudit[]
  aiChecks      AiCheck[]

  @@index([pageId])
  @@index([section, status])
  @@index([lastAiCheckDate]) // drives the AI re-verification priority queue
  @@index([status])
}

model Verification {
  id                String                 @id @default(cuid())
  factId            String
  userId            String
  actionType        VerificationActionType
  notes             String?                @db.Text // required for FLAG + SUGGEST_UPDATE
  proposedValue     String?                @db.Text // for SUGGEST_UPDATE
  proposedSourceUrl String? // for SUGGEST_UPDATE
  resolutionStatus  VerificationResolution @default(PENDING)
  resolvedAt        DateTime?
  resolvedBy        String? // admin User.id
  createdAt         DateTime               @default(now())

  fact   Fact                @relation(fields: [factId], references: [id], onDelete: Cascade)
  user   User                @relation("UserVerifications", fields: [userId], references: [id], onDelete: Cascade)
  audits VerificationAudit[]

  @@unique([factId, userId, actionType])
  @@index([factId])
  @@index([userId])
  @@index([resolutionStatus])
}

// Full AI verification history. Fact.lastAiCheckDate is the hot cache;
// this table is the audit trail.
model AiCheck {
  id             String        @id @default(cuid())
  factId         String
  checkResult    AICheckResult
  extractedValue String?       @db.Text // what the AI read from the source
  displayedValue String        @db.Text // what Shishya showed at check time
  matchType      AiMatchType   @default(EXACT)
  notes          String?       @db.Text
  latencyMs      Int?
  modelUsed      String? // "claude-haiku-4-5"
  createdAt      DateTime      @default(now())

  fact Fact @relation(fields: [factId], references: [id], onDelete: Cascade)

  @@index([factId, createdAt])
}

// Admin audit log — random 5% sampling + dispute resolution decisions.
model VerificationAudit {
  id             String      @id @default(cuid())
  factId         String
  verificationId String?
  adminUserId    String
  auditResult    AuditResult
  notes          String?     @db.Text
  createdAt      DateTime    @default(now())

  fact         Fact          @relation(fields: [factId], references: [id], onDelete: Cascade)
  verification Verification? @relation(fields: [verificationId], references: [id])
  admin        User          @relation("AdminAudits", fields: [adminUserId], references: [id])

  @@index([factId])
  @@index([adminUserId])
}

enum FactSection {
  EXAM
  COLLEGE
  SCHOLARSHIP
  BOARD
  UNIVERSITY // for the Worldwide section
  VISA // for the Worldwide section
  CAREER
  GENERAL
}

enum AICheckResult {
  VERIFIED
  NEEDS_REVIEW
  SOURCE_UNREACHABLE
  SOURCE_CHANGED
}

enum AiMatchType {
  EXACT
  CLOSE // e.g. date format difference
  PARTIAL
  MISMATCH
}

enum FactStatus {
  NONE // grey badge — no verification yet
  AI // blue — AI-verified, no human yet
  VERIFIED // green single-check
  FULLY // green double-check
  NEEDS_REVIEW // amber
  DISPUTED // red
}

enum VerificationActionType {
  VERIFY
  FLAG
  SUGGEST_UPDATE
}

enum VerificationResolution {
  PENDING
  VALIDATED // flag was correct / suggestion accepted
  DISMISSED // flag was wrong
}

enum AuditResult {
  APPROVED
  REJECTED
  CORRECTED
}

enum BadgeLevel {
  NEWCOMER
  CONTRIBUTOR
  VERIFIER
  TRUSTED_VERIFIER
  DOMAIN_EXPERT
}

// ─────────────────────────────────────────────────────────────────────────
// Phase 1.2 — Domain Expert credentials
//
// Users claim affiliation with a recognized institution (IIT, AIIMS,
// UPSC etc.). Verification paths:
//   1. Institutional email (blocked — needs email infra; flow stubbed)
//   2. Community vouching (3 vouches by existing Domain Experts in the
//      same credential domain → auto-promote)
//   3. Admin manual grant (bootstrap path until the first DEs exist)
//
// On verification, the credential gets stamped + the user's badgeLevel
// promotes to DOMAIN_EXPERT (idempotent: if already DOMAIN_EXPERT we
// just append the credential).
//
// User.domainExpertCredentials Json column is the cached read-side
// view. The UserCredential table is the source of truth.
// ─────────────────────────────────────────────────────────────────────────

model UserCredential {
  id            String                 @id @default(cuid())
  userId        String
  // What credential domain this proves (matches CredentialDomain in
  // src/lib/institutional-domains.ts — kept as a free string here so
  // adding a domain in code doesn't require a schema migration).
  domain        String
  // "alumnus", "current_student", "currently_at", "working_at",
  // "exam_cleared" — free text, validated by the form.
  claimType     String
  // Institution display name, e.g., "IIT Madras", "UPSC".
  institution   String
  // Verification status of THIS credential row.
  status        CredentialStatus       @default(PENDING)
  // How it was verified once status flips to VERIFIED.
  verifiedVia   CredentialVerifiedVia?
  // The email used (if verifiedVia = INSTITUTIONAL_EMAIL); blanked
  // post-verification per privacy rule.
  verifiedEmail String?
  verifiedAt    DateTime?
  // Admin who manually granted (if verifiedVia = ADMIN_GRANT) or
  // approved the credential (if applicable). NULL otherwise.
  approvedBy    String?
  // Optional context from the user when claiming (year of graduation,
  // department, etc.) — stays even after verification.
  notes         String?                @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    User              @relation("UserCredentials", fields: [userId], references: [id], onDelete: Cascade)
  vouches CredentialVouch[]

  @@index([userId])
  @@index([status])
  @@index([domain, status])
}

model CredentialVouch {
  id            String   @id @default(cuid())
  credentialId  String
  // Voucher must themselves be a verified DOMAIN_EXPERT in the same
  // domain (enforced in application code; not in schema constraint
  // because the check requires cross-table logic).
  voucherUserId String
  comment       String?  @db.Text
  createdAt     DateTime @default(now())

  credential UserCredential @relation(fields: [credentialId], references: [id], onDelete: Cascade)
  voucher    User           @relation("UserVouches", fields: [voucherUserId], references: [id], onDelete: Cascade)

  @@unique([credentialId, voucherUserId])
  @@index([credentialId])
  @@index([voucherUserId])
}

enum CredentialStatus {
  PENDING // claim submitted, awaiting verification path completion
  VERIFIED // verification path completed — user is now DOMAIN_EXPERT
  REJECTED // admin rejected the claim
  REVOKED // previously verified but later revoked (e.g., fraud)
}

enum CredentialVerifiedVia {
  INSTITUTIONAL_EMAIL // one-time link sent to verified email domain
  COMMUNITY_VOUCHING // 3+ existing DEs in the same domain vouched
  ADMIN_GRANT // admin granted manually (bootstrap path)
  DOCUMENT_REVIEW // admin reviewed an uploaded doc (Phase 1.2.x)
}

// ─────────────────────────────────────────────────────────────────────
// AnalyticsEvent — first-party event log for product decisions.
//
// We don't ship a 3rd-party tracker (no Plausible/Umami) because the
// only signals worth tracking can live in the same Postgres that
// already powers the rest of the platform. Privacy-first: no PII
// stored beyond userId (when signed in); anonymous users get a UUID
// in an httpOnly cookie that resets every 30 days.
//
// EventKind covers the 7 product-decision-critical actions on the
// platform. Additional `props` (Json) lets each event carry tiny
// payload — exam code, scholarship id, etc. — without needing
// schema changes for new variants.
// ─────────────────────────────────────────────────────────────────────
model AnalyticsEvent {
  id          String    @id @default(cuid())
  kind        EventKind
  // Authenticated user id when signed in; NULL for anonymous.
  userId      String?
  // Stable cookie-based anonymous id. Set to NULL when userId is set
  // (we don't double-count). 30-day rotating cookie.
  anonId      String?
  // Pathname the event fired on. Useful for PAGE_VIEW + for joining
  // an event to its source page.
  path        String?
  // Free-form event payload (max 1 KB enforced at write-time):
  //   { examCode, factId, scholarshipId, score, total, ... }
  props       Json?
  // First-party UTM capture — only set when the event has them on the URL.
  utmSource   String?
  utmMedium   String?
  utmCampaign String?
  // Truncated referrer hostname (e.g., "google.com"), not full URL.
  refHost     String?
  createdAt   DateTime  @default(now())

  @@index([kind, createdAt])
  @@index([userId, createdAt])
  @@index([anonId, createdAt])
  @@index([path])
  @@index([createdAt])
}

enum EventKind {
  PAGE_VIEW
  SIGNUP // fires on the user's very first auth callback
  VERIFICATION_SUBMITTED // user clicked Verify / Flag / Suggest on a Fact
  QUIZ_ATTEMPTED // user submitted a chapter quiz (regardless of score)
  CHAPTER_COMPLETED // user scored >=80% on a chapter quiz
  SCHOLARSHIP_SAVED // user clicked "Save scholarship" — local + event
  CHAT_OPENED // user opened /chat (the AI tutor)
  CTA_CLICKED // generic — for ad-hoc button instrumentation
}

// ─────────────────────────────────────────────────────────────────────
// Notification — in-app + email-digest delivery for events that
// concern a specific user. Created by application code (no DB
// triggers) so we control timing + dedup precisely.
//
// Email digest is OFF at platform-level (no email infra yet). The
// `emailedAt` field exists so when Resend/SendGrid lands we can scan
// the table for un-emailed unread rows and batch-send.
// ─────────────────────────────────────────────────────────────────────
model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  // Headline shown in the bell dropdown + on /me/notifications.
  title     String
  // Optional one-line context (e.g., "JEE Main 2026 application dates").
  body      String?          @db.Text
  // Where clicking the notification takes the user. Relative path.
  link      String?
  // Dedup key — application code passes a stable string so the same
  // event can't create two notifications. Optional.
  dedupKey  String?
  readAt    DateTime?
  emailedAt DateTime?
  createdAt DateTime         @default(now())

  user User @relation("UserNotifications", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, dedupKey])
  @@index([userId, readAt])
  @@index([userId, createdAt])
  @@index([emailedAt])
}

enum NotificationType {
  // Verification events
  VERIFICATION_APPROVED // your verification got APPROVED in audit
  VERIFICATION_REJECTED // your verification got REJECTED in audit
  VERIFICATION_CORRECTED // admin corrected your verification

  // Credential events
  CREDENTIAL_VOUCHED // someone vouched for your credential
  CREDENTIAL_VERIFIED // your credential got verified (you're now DE!)
  CREDENTIAL_REJECTED // admin rejected your credential claim

  // Badge / promotion events
  BADGE_PROMOTED // you got promoted to next badge level

  // Flag follow-up
  FLAG_VALIDATED // a flag you raised was validated
  SUGGESTION_ACCEPTED // an update suggestion you submitted was accepted

  // Misc
  ADMIN_MESSAGE // free-form admin-issued notification
}

// ─────────────────────────────────────────────────────────────────────────
// PHASE 2: INSTITUTIONS
//
// Coaching centers + training providers who want to list their services
// on Shishya and manage their own student cohorts. Auth is intentionally
// separate from the student User table — institutions sign in with email
// + password (bcrypt-hashed), get a JWT cookie, and operate via /i/*
// surfaces. Students stay on Google OAuth.
//
// Relationship shape:
//   Institution
//     ├── InstitutionUser[]       (admins / teachers — email+password)
//     ├── Course[]
//     │     └── Batch[]
//     │           └── BatchEnrollment[] → User (student)
//     └── InstitutionReview[] (by Users — students)
// ─────────────────────────────────────────────────────────────────────────

model Institution {
  id           String   @id @default(cuid())
  // URL-safe slug for /institutions/<slug>. Auto-generated from name
  // at creation, immutable after.
  slug         String   @unique
  name         String
  // 1-line marketing pitch shown under the name on the profile.
  tagline      String?
  description  String?  @db.Text
  logoUrl      String?
  websiteUrl   String?
  // Primary contact (shown publicly on profile). Used for inbound
  // student enquiries — not for auth (that lives on InstitutionUser).
  contactEmail String
  contactPhone String?
  // Location for "coaching near me" filters. India-only for v1.
  city         String?
  // ISO 2-letter state code matching INDIAN_STATES in src/lib/states.
  state        String?
  // ["ONLINE", "OFFLINE", "HYBRID"] — postgres String[] array.
  modes        String[] @default([])
  // Exam codes this institution coaches for. Cross-references Exam.code.
  examCodes    String[] @default([])
  // Public discoverability. We default to TRUE because the model is
  // fully self-service + free — institutions list themselves, they want
  // visibility. Set to false to soft-hide (e.g. spammy listing).
  active       Boolean  @default(true)
  // True once Shishya admin manually verifies the institution exists.
  // Public profile shows a "Pending verification" badge while false,
  // a green ✓ once true. v1 self-service: defaults to false, admin
  // promotes later.
  verified     Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  admins  InstitutionUser[]
  courses Course[]
  reviews InstitutionReview[]

  @@index([slug])
  @@index([state])
  @@index([active, verified])
}

model InstitutionUser {
  id            String          @id @default(cuid())
  institutionId String
  email         String          @unique
  // bcrypt hash with cost 12. Never exposed in any API response.
  passwordHash  String
  name          String
  role          InstitutionRole @default(ADMIN)
  // Session-revocation token — bumped on logout-everywhere or password
  // change. JWT-issued sessions check this matches before granting
  // access, so a leaked cookie can be invalidated server-side.
  sessionEpoch  Int             @default(0)
  lastLoginAt   DateTime?
  createdAt     DateTime        @default(now())

  institution Institution @relation(fields: [institutionId], references: [id], onDelete: Cascade)

  @@index([email])
  @@index([institutionId])
}

enum InstitutionRole {
  ADMIN // can edit institution profile + manage all batches
  TEACHER // can manage batches assigned to them (v2 — schema-ready)
}

model Course {
  id            String   @id @default(cuid())
  institutionId String
  // Optional link to an Exam (e.g. SSC_CGL). When set, the course
  // shows up on the per-exam page's "coaching centers" section.
  examCode      String?
  name          String // e.g. "SSC CGL Foundation 2026"
  description   String?  @db.Text
  durationWeeks Int?
  // Fees in INR rupees. Null = "contact us". Stored as integer to
  // avoid floating-point pricing bugs.
  feesInr       Int?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  institution Institution @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  batches     Batch[]

  @@index([institutionId])
  @@index([examCode])
}

model Batch {
  id         String    @id @default(cuid())
  courseId   String
  name       String // e.g. "Morning batch — Aug 2026"
  startDate  DateTime?
  endDate    DateTime?
  // "ONLINE" | "OFFLINE" | "HYBRID" — same set as Institution.modes.
  mode       String    @default("ONLINE")
  // Shareable invite link suffix. Goes in /join/<inviteCode>. cuid
  // gives us collision-free unguessable codes without needing crypto.
  inviteCode String    @unique @default(cuid())
  // Optional cap on how many students can enroll. Null = unlimited.
  capacity   Int?
  // Soft-archive (so old batches stay queryable for outcomes/results
  // but don't surface in the active student-add UI).
  archived   Boolean   @default(false)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  course      Course            @relation(fields: [courseId], references: [id], onDelete: Cascade)
  enrollments BatchEnrollment[]

  @@index([courseId])
  @@index([inviteCode])
}

model BatchEnrollment {
  id         String   @id @default(cuid())
  batchId    String
  userId     String
  enrolledAt DateTime @default(now())
  // "ACTIVE" | "LEFT" | "COMPLETED"
  status     String   @default("ACTIVE")

  batch Batch @relation(fields: [batchId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  // One enrollment per (batch, user) — re-clicking the invite link
  // doesn't duplicate; the API just bumps status back to ACTIVE.
  @@unique([batchId, userId])
  @@index([userId])
}

model InstitutionReview {
  id            String   @id @default(cuid())
  institutionId String
  userId        String
  // 1-5 stars.
  rating        Int
  body          String   @db.Text
  // Moderation: visible publicly only when status = APPROVED.
  status        String   @default("PENDING") // PENDING | APPROVED | REJECTED
  createdAt     DateTime @default(now())

  institution Institution @relation(fields: [institutionId], references: [id], onDelete: Cascade)

  @@unique([institutionId, userId])
  @@index([institutionId, status])
}

// ─────────────────────────────────────────────────────────────────────────
// KNOWLEDGE SPINE — grounded, provenance-tracked source corpus (RAG)
//
// Every chunk the AI retrieves traces back to a KnowledgeSource with a
// reliability tier, so answers can cite *where* a fact came from and the
// UI can badge official sources differently from community ones.
//
// Embeddings live in an Unsupported("vector") column (pgvector on Neon).
// Run `npm run kb:setup` once per database to CREATE EXTENSION vector.
// Similarity search goes through raw SQL in src/lib/ai/kb/retrieve.ts —
// Prisma cannot query vector columns natively.
// ─────────────────────────────────────────────────────────────────────────

model KnowledgeSource {
  id          String            @id @default(cuid())
  title       String
  // Where the content came from — the provenance anchor.
  url         String?
  publisher   String? // e.g. "SSC", "NTA", "NCERT", "Shishya"
  tier        SourceReliability
  // Scope: null examId = cross-exam (e.g. NCERT chapters used by many exams)
  examCode    String?
  topicCode   String?
  language    Language          @default(EN)
  // Content hash of the ingested document — dedupes re-ingestion.
  contentHash String            @unique
  // When the underlying source was published / last known-good.
  publishedAt DateTime?
  ingestedAt  DateTime          @default(now())
  // Soft retirement: stale notifications etc. stay for audit, leave retrieval.
  archivedAt  DateTime?

  chunks KnowledgeChunk[]

  @@index([examCode, topicCode])
  @@index([tier])
}

model KnowledgeChunk {
  id        String                       @id @default(cuid())
  sourceId  String
  // Position of this chunk within the source document.
  seq       Int
  // Heading breadcrumb for display + retrieval context, e.g.
  // "Percentage > Successive change".
  heading   String?
  text      String                       @db.Text
  tokenEst  Int                          @default(0)
  embedding Unsupported("vector(1024)")?
  createdAt DateTime                     @default(now())

  source KnowledgeSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)

  @@unique([sourceId, seq])
  @@index([sourceId])
}

enum SourceReliability {
  OFFICIAL // govt notification, official exam-body page, gazette
  STANDARD_TEXT // NCERT / standard reference textbook
  PYQ // previous-year question paper (with year)
  CURATED // Shishya-authored, SME-reviewed material
  COMMUNITY // community-contributed, unverified
}

// ─────────────────────────────────────────────────────────────────────────
// STUDENT MODEL — psychometric state (IRT ability, item stats, FSRS review)
//
// Replaces the flat WeaknessMap.masteryScore as the *engine* (WeaknessMap
// stays as the UI-facing projection). Pure math lives in
// src/lib/psychometrics/*; these tables are its persisted state.
// ─────────────────────────────────────────────────────────────────────────

// Per-question IRT item parameters, calibrated online from real attempts.
// Seeded from the content-factory verifier's difficulty estimate; refined
// by every answer (Elo-style update with decaying K).
model QuestionStat {
  id            String   @id @default(cuid())
  questionId    String   @unique
  // 2PL parameters: difficulty b (logit scale, ~ -3..+3), discrimination a.
  irtB          Float    @default(0)
  irtA          Float    @default(1)
  attemptsCount Int      @default(0)
  correctCount  Int      @default(0)
  avgTimeSec    Float?
  updatedAt     DateTime @updatedAt

  @@index([attemptsCount])
}

// Per-student, per-subject latent ability θ with a standard error that
// shrinks as evidence accumulates. Subject-level (not topic) keeps θ
// estimable from realistic attempt volumes; topic detail comes from FSRS
// + WeaknessMap.
model AbilityState {
  id            String   @id @default(cuid())
  userId        String
  examId        String
  subjectId     String
  theta         Float    @default(0)
  // Standard error of θ — drives CAT item selection + K decay.
  se            Float    @default(1)
  attemptsCount Int      @default(0)
  updatedAt     DateTime @updatedAt

  @@unique([userId, subjectId])
  @@index([userId, examId])
}

// FSRS spaced-repetition state per (user, topic). Drives "what to revise
// today" — retrievability decays over time; reviews reschedule.
model ReviewState {
  id         String    @id @default(cuid())
  userId     String
  examId     String
  topicId    String
  // FSRS core state
  stability  Float     @default(1) // days until retrievability drops to 90%
  difficulty Float     @default(5) // FSRS difficulty 1..10
  reps       Int       @default(0)
  lapses     Int       @default(0)
  lastReview DateTime?
  due        DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  exam  Exam  @relation(fields: [examId], references: [id], onDelete: Cascade)
  topic Topic @relation(fields: [topicId], references: [id], onDelete: Cascade)

  @@unique([userId, topicId])
  @@index([userId, examId, due])
}

// ─────────────────────────────────────────────────────────────────────
// SurgeAptitudeAttempt — submissions to the 30-minute / 30-MCQ aptitude
// screening test used for Surge admissions. Standalone: no FK to User
// (candidates are external applicants who take the test as guests). The
// founder reviews passers via GET /api/admin/aptitude (Bearer-gated).
// ─────────────────────────────────────────────────────────────────────
model SurgeAptitudeAttempt {
  id          String   @id @default(cuid())
  name        String
  email       String
  phone       String?
  score       Int
  total       Int
  percent     Int
  passed      Boolean
  sections    Json? // { QUANT: {correct,total}, REASONING:{...}, VERBAL:{...} }
  durationSec Int?
  ip          String?
  userAgent   String?
  // Set when the "you cleared the cutoff — contact Nikhil" email has been
  // sent, so a candidate is never emailed twice (across retakes/backfills).
  passEmailedAt DateTime?
  createdAt   DateTime @default(now())

  @@index([createdAt])
  @@index([email])
  @@index([passed, createdAt])
}

// ─────────────────────────────────────────────────────────────────────
// GrowthReport — one row per weekly Gemini growth analysis. The cron
// computes a metrics snapshot, Gemini turns it into prioritized
// suggestions (each with a concrete brief for Claude to implement), and
// Claude updates each suggestion's status as it ships them. Closes the
// loop: analyse → build → re-measure next week.
// ─────────────────────────────────────────────────────────────────────
model GrowthReport {
  id          String   @id @default(cuid())
  weekStart   DateTime // start of the analysed 7-day window (UTC)
  metrics     Json     // computed growth metrics snapshot
  narrative   String?  @db.Text // Gemini's prose read of the week
  // [{ id, title, category, hypothesis, expectedImpact, effort,
  //    claudeTask, status: open|done|skipped, commit, note }]
  suggestions Json?
  model       String?  // Gemini model that produced it
  createdAt   DateTime @default(now())

  @@index([createdAt])
  @@index([weekStart])
}

// ─────────────────────────────────────────────────────────────────────
// CrackPathTask — shared state for the Gemini(architect)↔Claude(builder)
// design loop that builds the "Crack Path" (the learn → plan → daily-habit
// layer that takes a fresh aspirant zero-to-crack).
//
// Flow per task:  designed → (Claude builds) built → (Gemini reviews)
//   approved  ✅ done, or  needs_changes → (Claude revises) built → …
// ─────────────────────────────────────────────────────────────────────
model CrackPathTask {
  id                 String   @id @default(cuid())
  phase              String // "Learn" | "Plan" | "Habit" | ...
  seq                Int // global build order
  title              String
  spec               String   @db.Text // Gemini's design brief — what to build
  acceptanceCriteria Json? // string[] — how Gemini will judge it done
  effort             String? // S | M | L
  // designed | built | needs_changes | approved
  status             String   @default("designed")
  buildReport        String?  @db.Text // Claude's feedback: what it built + how it meets the criteria
  commit             String? // commit sha Claude shipped
  reviewFeedback     String?  @db.Text // Gemini's verdict on whether the build matches the design
  approved           Boolean  @default(false)
  iteration          Int      @default(0) // build/review round-trips
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([status])
  @@index([seq])
}

// ─────────────────────────────────────────────────────────────────────
// AnonTutorLog — captures anonymous (signed-out) AI-tutor turns so we can
// analyse the ungated-tutor experience (the biggest, previously-invisible
// segment). Privacy-first: keyed by the pseudonymous shishya_anon cookie
// UUID — no name/email/userId (anon users have none). Message text is the
// student's own exam question, capped, for product analysis only.
// ─────────────────────────────────────────────────────────────────────
model AnonTutorLog {
  id          String   @id @default(cuid())
  anonId      String? // pseudonymous shishya_anon cookie — groups a conversation
  examCode    String? // exam scope, null = general mode
  userMessage String   @db.Text
  reply       String?  @db.Text
  replyChars  Int? // length of the full reply (in case `reply` is truncated)
  createdAt   DateTime @default(now())

  @@index([anonId, createdAt])
  @@index([createdAt])
}
