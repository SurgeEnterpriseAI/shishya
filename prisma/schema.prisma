// Shishya — AI-tutored mock test platform
// Database schema for users, exams, syllabus, questions, mocks, attempts, AI tutoring.

generator client {
  provider      = "prisma-client-js"
  // "native" is the local-dev target (Windows on this machine); the rhel target
  // is what Vercel's build/serverless runtime uses on Linux.
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  // Runtime traffic uses the pooled (pgBouncer) Neon endpoint so a single
  // serverless function holds at most one Postgres connection. Without this,
  // 10k concurrent serverless invocations would each open direct sockets
  // and exhaust Neon's pool.
  url       = env("DATABASE_URL")
  // Prisma needs a direct (non-pooled) URL for `prisma migrate` / `db push`
  // because pgBouncer rejects the prepared-statement workflow they use.
  directUrl = env("DIRECT_URL")
}

// ─────────────────────────────────────────────────────────────────────────
// AUTH (NextAuth-compatible)
// ─────────────────────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  name          String?
  image         String?
  preferredLang Language  @default(EN)
  // First-time onboarding tour completion timestamp. Null = the user has
  // never finished the dashboard tour; <OnboardingTour /> auto-mounts in
  // that case. Set to NOW() on "Done" or "Skip" so it never re-appears.
  onboardedAt   DateTime?
  // Attribution: captured once on first signed-in page load from a
  // cookie set on /login. Tells us where this user came from when no
  // UTM params were on the URL (organic, Reddit, Telegram, etc.)
  // referrerUrl  = full Referer header (or stored UTM URL fragment)
  // referrerHost = parsed hostname for cheap GROUP BY queries
  signupReferrerUrl  String?
  signupReferrerHost String?
  // Verification-system contribution tracking. All default to 0 so the
  // migration is non-breaking — existing users land as NEWCOMER with
  // zero counts. Counts are incremented by the verification flow,
  // resetting only on admin override (e.g., when a flag is invalidated
  // we DECREMENT flagValidatedCount).
  contributionScore       Int        @default(0)
  verificationCount       Int        @default(0)
  flagCount               Int        @default(0)
  flagValidatedCount      Int        @default(0)
  suggestionAcceptedCount Int        @default(0)
  badgeLevel              BadgeLevel @default(NEWCOMER)
  badgeEarnedAt           DateTime?
  // [{ type: "exam_cleared" | "currently_at" | "working_at", domain: "UPSC", verifiedAt: ISO, source: "linkedin" | "doc" | "vouching" | "email" }]
  domainExpertCredentials Json?
  // Public-profile opt-in. When TRUE + `handle` is non-null, the user's
  // contribution profile is exposed at /u/[handle] for SEO + recognition.
  // Default FALSE — users must opt in explicitly (no dark pattern of
  // public-by-default).
  profilePublic           Boolean    @default(false)
  // URL handle for /u/[handle]. Unique across the platform. Null until
  // the user picks one in /me/settings. Validated to ^[a-z0-9_-]{3,30}$.
  handle                  String?    @unique
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts        Account[]
  sessions        Session[]
  enrollments     Enrollment[]
  mocks           Mock[]
  attempts        Attempt[]
  weaknessMaps    WeaknessMap[]
  chatSessions    ChatSession[]
  progressEvents  ProgressEvent[]
  discussions     Discussion[]        @relation("DiscussionAuthor")
  discussionMessages DiscussionMessage[] @relation("MessageAuthor")
  questionReports QuestionReport[]
  featureRequests FeatureRequest[]       @relation("FeatureRequestAuthor")
  featureUpvotes  FeatureRequestUpvote[] @relation("FeatureRequestVoter")
  dailyBriefs     DailyBrief[]
  verifications   Verification[]      @relation("UserVerifications")
  adminAudits     VerificationAudit[] @relation("AdminAudits")
  credentials     UserCredential[]    @relation("UserCredentials")
  vouches         CredentialVouch[]   @relation("UserVouches")
  notifications   Notification[]      @relation("UserNotifications")

  @@index([email])
  @@index([badgeLevel])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─────────────────────────────────────────────────────────────────────────
// EXAMS & SYLLABUS
// ─────────────────────────────────────────────────────────────────────────

model Exam {
  id            String   @id @default(cuid())
  code          String   @unique // e.g. "SSC_CGL", "NEET_UG"
  name          String              // "SSC CGL Tier 1"
  shortName     String              // "SSC CGL"
  category      ExamCategory
  description   String   @db.Text
  durationMin   Int                 // exam duration in minutes
  totalQuestions Int                // total Qs in real exam
  totalMarks    Float
  marksPerQ     Float
  negativeMark  Float    @default(0)
  languages     Language[]          // languages exam is offered in
  active        Boolean  @default(true)
  candidatesPerYear Int?            // approximate annual volume
  // ISO state code for STATE_LEVEL exams (TN, KA, MH, UP, ...). Null for
  // national/central exams. Drives the StatePicker grouping.
  state         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  subjects    Subject[]
  questions   Question[]
  mocks       Mock[]
  enrollments Enrollment[]
  weaknessMaps WeaknessMap[]
  chatSessions ChatSession[]
  discussions  Discussion[]
  newsItems    ExamNewsItem[]
  importantDates ExamImportantDate[]
  rankBands    ExamRankBand[]

  @@index([code])
  @@index([active])
  @@index([category, state])
}

model Subject {
  id        String   @id @default(cuid())
  examId    String
  code      String   // e.g. "QUANT", "REASONING"
  name      String   // "Quantitative Aptitude"
  weight    Float    @default(1) // relative weightage
  orderIdx  Int      @default(0)
  createdAt DateTime @default(now())

  exam   Exam    @relation(fields: [examId], references: [id], onDelete: Cascade)
  topics Topic[]

  @@unique([examId, code])
  @@index([examId])
}

model Topic {
  id          String   @id @default(cuid())
  subjectId   String
  parentId    String?  // null for top-level topics; otherwise subtopic
  code        String   // e.g. "quant.percentage"
  name        String
  description String?  @db.Text
  syllabusText String? @db.Text  // detailed syllabus content for AI context
  // Student-facing study material (markdown). Populated by
  // scripts/generate-topic-notes.ts. Sectioned: overview, key concepts,
  // formulas, worked examples, common mistakes, quick reference.
  notes              String?   @db.Text
  notesGeneratedAt   DateTime?
  notesGeneratedBy   String?
  weight      Float    @default(1)
  orderIdx    Int      @default(0)
  createdAt   DateTime @default(now())

  subject   Subject @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  parent    Topic?  @relation("TopicTree", fields: [parentId], references: [id], onDelete: SetNull)
  children  Topic[] @relation("TopicTree")
  questions Question[]
  weaknessMaps WeaknessMap[]

  @@unique([subjectId, code])
  @@index([parentId])
}

// ─────────────────────────────────────────────────────────────────────────
// QUESTIONS
// ─────────────────────────────────────────────────────────────────────────

model Question {
  id          String        @id @default(cuid())
  examId      String
  topicId     String
  type        QuestionType  @default(MCQ)
  difficulty  Difficulty    @default(MEDIUM)
  body        String        @db.Text
  options     Json          // [{ key: "A", text: "..." }, ...]
  answerKey   String        // "A" | "B" | "C" | "D" — or comma-separated for multi-select
  solution    String        @db.Text
  hints       Json?         // optional array of progressive hints
  language    Language      @default(EN)
  source      QuestionSource @default(SME)
  validated   Boolean       @default(false)
  validatedBy String?
  validatedAt DateTime?
  tags        String[]      @default([])
  pyqYear     Int?          // previous-year-question year, if applicable
  metadata    Json?         // freeform: estimated time, similar Qs, etc.
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  exam         Exam                  @relation(fields: [examId], references: [id], onDelete: Cascade)
  topic        Topic                 @relation(fields: [topicId], references: [id], onDelete: Cascade)
  reports      QuestionReport[]
  translations QuestionTranslation[]

  @@index([examId, topicId])
  @@index([difficulty])
  @@index([validated])
  @@index([language])
}

// Student-flagged questions. The student notices the answer key, the
// solution, the question body, or the options look wrong; they click
// "Report" on the per-question review and we capture their reason here.
// Admin reviews under /admin and fixes / removes the question.
model QuestionReport {
  id          String   @id @default(cuid())
  questionId  String
  userId      String?  // null when reported by a signed-out flow
  reason      String   @db.Text
  resolved    Boolean  @default(false)
  resolvedBy  String?
  resolvedAt  DateTime?
  createdAt   DateTime @default(now())

  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  user     User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([questionId])
  @@index([resolved])
  @@index([createdAt])
}

// In-product feature requests. Students click a tiny floating pill on
// any page and tell us what feature they want; the request is auto-
// tagged with the route they were on and the area (Mock tests / Tutor /
// Translations / Results / UI / Other) so we can slice volume by where
// the friction lives. Public /ideas board lets others upvote.
model FeatureRequest {
  id          String   @id @default(cuid())
  // First-sentence derivation server-side; full text goes in body.
  title       String   @db.Text
  body        String   @db.Text
  // Auto-tagged page context
  routePath   String   // e.g. /exams/SSC_CGL/topics/quant.percentage
  area        String   // "Mock tests" | "AI Tutor" | "Translations" | "Results & Rank" | "UI / Navigation" | "Other"
  examCode    String?  // populated when the route is exam-scoped
  // Author — null when signed-out flow (we still capture impulse ideas)
  authorId    String?
  authorName  String?
  authorEmail String?
  // Triage by admin
  status      FeatureRequestStatus @default(OPEN)
  adminNote   String?  @db.Text
  // Social proof — denormalised count, source of truth is FeatureRequestUpvote
  upvoteCount Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  author  User?                  @relation("FeatureRequestAuthor", fields: [authorId], references: [id], onDelete: SetNull)
  upvotes FeatureRequestUpvote[]

  @@index([status, upvoteCount])
  @@index([area, createdAt])
  @@index([createdAt])
}

// One upvote per (requestId, userId). Anonymous upvoting isn't allowed
// because we want one-person-one-vote to prevent gaming the ideas board.
model FeatureRequestUpvote {
  id        String   @id @default(cuid())
  requestId String
  userId    String
  createdAt DateTime @default(now())

  request FeatureRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  user    User           @relation("FeatureRequestVoter", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([requestId, userId])
  @@index([userId])
}

// Question translations. A question authored in EN (or any base language)
// gets translated on-demand into the student's chosen locale and the result
// is cached here so the next student to pick the same language gets it
// instantly. Locale is a string (not the Language enum) so we can support
// every locale our i18n UI dictionary supports — including Sanskrit,
// Konkani, Manipuri, etc. that the user-facing Language enum doesn't list.
model QuestionTranslation {
  id          String   @id @default(cuid())
  questionId  String
  locale      String   // matches i18n.ts locale codes: "hi", "te", "ta", "bn", ...
  body        String   @db.Text
  options     Json     // [{ key: "A", text: "<translated>" }, ...]
  solution    String   @db.Text
  hints       Json?
  // The model + prompt version that produced this translation. Lets us
  // re-translate if we change either later.
  generator   String?
  createdAt   DateTime @default(now())

  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([questionId, locale])
  @@index([locale])
}

// ─────────────────────────────────────────────────────────────────────────
// ENROLLMENTS — student joining an exam track
// ─────────────────────────────────────────────────────────────────────────

model Enrollment {
  id        String   @id @default(cuid())
  userId    String
  examId    String
  targetDate DateTime?  // when the student plans to take the exam
  goalScore Float?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  exam Exam @relation(fields: [examId], references: [id], onDelete: Cascade)

  @@unique([userId, examId])
  @@index([userId])
}

// ─────────────────────────────────────────────────────────────────────────
// MOCKS & ATTEMPTS
// ─────────────────────────────────────────────────────────────────────────

model Mock {
  id          String     @id @default(cuid())
  userId      String?    // null for system templates available to all users
  examId      String
  type        MockType
  title       String
  config      Json       // { topics: [...], difficultyMix: {...}, count, durationMin }
  questionIds String[]   // ordered list of Question.id
  generatedBy String     @default("system") // "system" | "ai" | "ai:diagnostic" | "user-request"
  generationContext Json? // snapshot of student state at generation time
  createdAt   DateTime   @default(now())

  user     User?     @relation(fields: [userId], references: [id], onDelete: Cascade)
  exam     Exam      @relation(fields: [examId], references: [id], onDelete: Cascade)
  attempts Attempt[]
  dailyBriefs DailyBrief[]

  @@index([userId, examId])
  @@index([type])
}

model Attempt {
  id          String        @id @default(cuid())
  mockId      String
  userId      String
  status      AttemptStatus @default(IN_PROGRESS)
  startedAt   DateTime      @default(now())
  finishedAt  DateTime?
  durationSec Int?
  answers     Json          // [{ questionId, chosen, correct, timeSec, marked }]
  scoreRaw    Float?
  scoreMax    Float?
  scorePct    Float?
  topicScores Json?         // { topicId: { correct, total, score } }
  rank        Int?
  percentile  Float?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  mock Mock @relation(fields: [mockId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, mockId])
  @@index([status])
}

// ─────────────────────────────────────────────────────────────────────────
// AI STATE — weakness map, chat sessions, progress
// ─────────────────────────────────────────────────────────────────────────

model WeaknessMap {
  id          String   @id @default(cuid())
  userId      String
  examId      String
  topicId     String
  masteryScore Float   @default(0) // 0.0 – 1.0
  attemptsCount Int    @default(0)
  correctCount Int     @default(0)
  avgTimeSec  Float?
  lastSeenAt  DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  exam  Exam  @relation(fields: [examId], references: [id], onDelete: Cascade)
  topic Topic @relation(fields: [topicId], references: [id], onDelete: Cascade)

  @@unique([userId, examId, topicId])
  @@index([userId, examId])
}

model ChatSession {
  id        String   @id @default(cuid())
  userId    String
  examId    String?
  title     String?
  contextSnapshot Json? // student state at session start
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  exam     Exam?          @relation(fields: [examId], references: [id], onDelete: SetNull)
  messages ChatMessage[]

  @@index([userId])
}

model ChatMessage {
  id        String   @id @default(cuid())
  sessionId String
  role      ChatRole
  content   String   @db.Text
  toolCalls Json?    // tool calls made by Claude in this turn
  metadata  Json?    // tokens used, cache hits, latency
  createdAt DateTime @default(now())

  session ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, createdAt])
}

model ProgressEvent {
  id        String        @id @default(cuid())
  userId    String
  examId    String?
  type      ProgressType
  delta     Float?        // numeric change (score, mastery, etc.)
  metadata  Json?
  createdAt DateTime      @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([type])
}

// Daily brief generated overnight by /api/cron/daily-brief.
// One row per (user, exam, calendar day) — uniqueness lets the cron be
// re-runnable safely. The dashboard's "Today's recommended mock" card
// reads the most-recent brief for each enrolled exam and shows the
// reflection + a deep-link to the pre-built adaptive mock.
model DailyBrief {
  id          String   @id @default(cuid())
  userId      String
  examId      String
  // Day this brief is for, normalised to 00:00 UTC. Lets us upsert by
  // (user, exam, day) and ensures one brief per calendar day.
  briefDate   DateTime @db.Date
  // 2–3 sentence reflection from Shishya: what the student worked on,
  // what to focus on today, why. Markdown allowed but kept short.
  reflection  String   @db.Text
  // Pointer to the pre-generated adaptive mock for the student to take.
  // Nullable so reflection-only briefs (e.g. mock-pool too thin) still work.
  mockId      String?
  // Snapshot of the inputs used (mastery weakest topics, top asked-about
  // topics) — handy for debugging cron output.
  inputs      Json?
  createdAt   DateTime @default(now())

  user User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  mock Mock? @relation(fields: [mockId], references: [id], onDelete: SetNull)

  @@unique([userId, examId, briefDate])
  @@index([userId, briefDate])
}

// ─────────────────────────────────────────────────────────────────────────
// COMMUNITY — discussion threads & messages (visible on home page)
// ─────────────────────────────────────────────────────────────────────────

model Discussion {
  id             String       @id @default(cuid())
  title          String
  // Optional exam scope. When non-null, the discussion appears on that exam's
  // page in addition to the global discussions list.
  examId         String?
  // Author at thread creation. Display name is denormalised so list views
  // don't have to JOIN to render.
  authorId       String?
  authorName     String?
  // Denormalised counters / activity timestamp keep the home-page list cheap.
  lastActivityAt DateTime     @default(now())
  messageCount   Int          @default(0)
  locked         Boolean      @default(false)
  // Sticky / pinned threads bubble to the top of the home list.
  pinned         Boolean      @default(false)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  exam     Exam?               @relation(fields: [examId], references: [id], onDelete: SetNull)
  author   User?               @relation("DiscussionAuthor", fields: [authorId], references: [id], onDelete: SetNull)
  messages DiscussionMessage[]

  @@index([lastActivityAt])
  @@index([examId])
  @@index([pinned, lastActivityAt])
}

model DiscussionMessage {
  id           String   @id @default(cuid())
  threadId     String
  authorId     String?
  authorName   String?
  content      String   @db.Text
  createdAt    DateTime @default(now())

  thread Discussion @relation(fields: [threadId], references: [id], onDelete: Cascade)
  author User?      @relation("MessageAuthor", fields: [authorId], references: [id], onDelete: SetNull)

  @@index([threadId, createdAt])
}

// ─────────────────────────────────────────────────────────────────────────
// EXAM TIMELINE — news items & important dates per exam
// ─────────────────────────────────────────────────────────────────────────

model ExamNewsItem {
  id          String   @id @default(cuid())
  examId      String
  title       String
  body        String   @db.Text
  source      String?  // optional URL to official notice / news source
  publishedAt DateTime @default(now())
  createdAt   DateTime @default(now())

  exam Exam @relation(fields: [examId], references: [id], onDelete: Cascade)

  @@index([examId, publishedAt])
}

model ExamImportantDate {
  id        String   @id @default(cuid())
  examId    String
  label     String           // e.g. "Application opens", "Tier 1 exam date"
  date      DateTime
  isExamDay Boolean  @default(false) // highlight in UI
  source    String?           // optional URL
  notes     String?  @db.Text
  createdAt DateTime @default(now())

  exam Exam @relation(fields: [examId], references: [id], onDelete: Cascade)

  @@index([examId, date])
}

// Rank prediction. Maps a student's mock-score band → expected real-exam
// rank band → likely outcome (which college / which posting they're
// realistically in contention for). Used by the post-attempt "Rank card"
// on the results page and the exam landing page's "What can I get?" panel.
//
// Bands are coarse on purpose: 5-8 tiers per exam is enough resolution for
// motivation and goal-setting; ultra-precise rank prediction is not the
// platform's job. AI-seeded for top exams from Claude's knowledge of recent
// cut-off trends; admin can override per exam.
model ExamRankBand {
  id          String   @id @default(cuid())
  examId      String
  // The score window (mock percentage) that maps to this band. Inclusive.
  scorePctMin Float
  scorePctMax Float
  // Expected real-exam rank window. May be null for non-rank exams
  // (e.g. SSC where outcome is "post + cadre" rather than numeric rank).
  rankMin     Int?
  rankMax     Int?
  // Short label, e.g. "Top 1%", "Tier 1 IITs likely", "Group A posts".
  label       String
  // Markdown bullet list of outcomes. e.g.:
  //   - AIIMS Delhi (last year cut-off ~50)
  //   - JIPMER Puducherry
  //   - Top state government medical colleges
  outcomes    String   @db.Text
  // Order in which to display (lowest scorePctMin first ⇒ orderIdx 0 highest).
  orderIdx    Int      @default(0)
  source      String?  // "ai-generated:claude" or curated URL
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  exam Exam @relation(fields: [examId], references: [id], onDelete: Cascade)

  @@index([examId, orderIdx])
}

// ─────────────────────────────────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────────────────────────────────

enum FeatureRequestStatus {
  OPEN
  UNDER_REVIEW
  PLANNED
  SHIPPED
  DECLINED
}

enum Language {
  EN
  HI
  TE
  TA
  KN
  ML
  MR
  BN
  GU
  PA
}

enum ExamCategory {
  GOVT_JOBS       // SSC, RRB
  BANKING         // IBPS, SBI
  CIVIL_SERVICES  // UPSC
  MEDICAL         // NEET
  ENGINEERING     // JEE, GATE
  TEACHING        // CTET
  UNIVERSITY      // CUET
  MBA             // CAT
  LAW             // CLAT
  OLYMPIAD        // HBCSE, SOF, Silverzone, NSTSE, ZIO/INOI, PRIL
  STATE_LEVEL     // State PSC, State TET, State Police, etc.
  // SCHOOL_BOARD entries are (Board, Class) units used as containers
  // for school-level Subject + Topic data — NOT real entrance exams.
  // The /exams catalog filters these out; they're surfaced under
  // /schooling/[board]/class-[n] instead. Lets us reuse the existing
  // Subject/Topic/Question/Mock pipeline for school content without
  // duplicating the schema.
  SCHOOL_BOARD
  OTHER
}

enum QuestionType {
  MCQ           // single correct
  MSQ           // multiple correct
  NUMERIC       // type-the-number
  TRUE_FALSE
  MATCH         // matching pairs
  COMPREHENSION // passage-based parent (children are MCQs)
}

enum Difficulty {
  EASY
  MEDIUM
  HARD
}

enum QuestionSource {
  SME           // human subject-matter expert
  AI_GENERATED  // generated by Claude, awaiting validation
  AI_VALIDATED  // generated by Claude + reviewed by SME
  PYQ           // previous year question (legally sourced)
  COMMUNITY     // contributed by users
}

enum MockType {
  DIAGNOSTIC      // first mock to map weaknesses
  FULL            // mirrors real exam structure
  SUBJECT         // single subject focus
  TOPIC           // single topic drill
  ADAPTIVE        // AI-generated based on weakness map
  REVISION        // mistakes from past attempts
  CHALLENGE       // harder than current level
  USER_REQUEST    // user asked for specific config
}

enum AttemptStatus {
  IN_PROGRESS
  SUBMITTED
  ABANDONED
  AUTO_SUBMITTED
}

enum ChatRole {
  USER
  ASSISTANT
  SYSTEM
  TOOL
}

enum ProgressType {
  MOCK_COMPLETED
  TOPIC_MASTERED
  STREAK_DAY
  WEAKNESS_IMPROVED
  GOAL_REACHED
  RANK_CHANGE
}

// ─────────────────────────────────────────────────────────────────────────
// Verification system (Phase 2 of the trust-differentiator)
//
// One Fact row per verifiable claim across the platform. pageId is a
// polymorphic URL path ("/exams/jee-main", "/colleges/iit-madras") with
// a FactSection discriminator instead of 6 optional FKs. We trade
// referential integrity (a deleted Exam doesn't cascade-clean its Facts)
// for a single uniform Facts table — the spec treats facts as platform-
// wide objects, not per-entity rows.
// ─────────────────────────────────────────────────────────────────────────

model Fact {
  id                          String   @id @default(cuid())
  pageId                      String                        // canonical URL path, e.g. "/exams/jee-main"
  section                     FactSection                   // discriminator for the host page
  claimText                   String   @db.Text             // human-readable: "NIRF Engineering rank"
  claimValue                  String   @db.Text             // the actual value: "#1"
  sourceUrl                   String                        // official source URL
  sourceName                  String                        // "NIRF 2024", "CBSE", "NTA"
  originalIngestionDate       DateTime @default(now())
  lastAiCheckDate             DateTime?
  lastAiCheckResult           AICheckResult?
  aiCheckCount                Int      @default(0)
  communityVerificationsCount Int      @default(0)
  trustedVerifierCount        Int      @default(0)
  domainExpertCount           Int      @default(0)
  flagCount                   Int      @default(0)
  status                      FactStatus @default(NONE)
  createdAt                   DateTime @default(now())
  updatedAt                   DateTime @updatedAt

  verifications Verification[]
  audits        VerificationAudit[]
  aiChecks      AiCheck[]

  @@index([pageId])
  @@index([section, status])
  @@index([lastAiCheckDate])     // drives the AI re-verification priority queue
  @@index([status])
}

model Verification {
  id                String                  @id @default(cuid())
  factId            String
  userId            String
  actionType        VerificationActionType
  notes             String?                 @db.Text         // required for FLAG + SUGGEST_UPDATE
  proposedValue     String?                 @db.Text         // for SUGGEST_UPDATE
  proposedSourceUrl String?                                  // for SUGGEST_UPDATE
  resolutionStatus  VerificationResolution  @default(PENDING)
  resolvedAt        DateTime?
  resolvedBy        String?                                  // admin User.id
  createdAt         DateTime                @default(now())

  fact   Fact                @relation(fields: [factId], references: [id], onDelete: Cascade)
  user   User                @relation("UserVerifications", fields: [userId], references: [id], onDelete: Cascade)
  audits VerificationAudit[]

  @@unique([factId, userId, actionType])
  @@index([factId])
  @@index([userId])
  @@index([resolutionStatus])
}

// Full AI verification history. Fact.lastAiCheckDate is the hot cache;
// this table is the audit trail.
model AiCheck {
  id              String         @id @default(cuid())
  factId          String
  checkResult     AICheckResult
  extractedValue  String?        @db.Text    // what the AI read from the source
  displayedValue  String         @db.Text    // what Shishya showed at check time
  matchType       AiMatchType    @default(EXACT)
  notes           String?        @db.Text
  latencyMs       Int?
  modelUsed       String?                    // "claude-haiku-4-5"
  createdAt       DateTime       @default(now())

  fact Fact @relation(fields: [factId], references: [id], onDelete: Cascade)

  @@index([factId, createdAt])
}

// Admin audit log — random 5% sampling + dispute resolution decisions.
model VerificationAudit {
  id              String        @id @default(cuid())
  factId          String
  verificationId  String?
  adminUserId     String
  auditResult     AuditResult
  notes           String?       @db.Text
  createdAt       DateTime      @default(now())

  fact         Fact          @relation(fields: [factId], references: [id], onDelete: Cascade)
  verification Verification? @relation(fields: [verificationId], references: [id])
  admin        User          @relation("AdminAudits", fields: [adminUserId], references: [id])

  @@index([factId])
  @@index([adminUserId])
}

enum FactSection {
  EXAM
  COLLEGE
  SCHOLARSHIP
  BOARD
  UNIVERSITY       // for the Worldwide section
  VISA             // for the Worldwide section
  CAREER
  GENERAL
}

enum AICheckResult {
  VERIFIED
  NEEDS_REVIEW
  SOURCE_UNREACHABLE
  SOURCE_CHANGED
}

enum AiMatchType {
  EXACT
  CLOSE            // e.g. date format difference
  PARTIAL
  MISMATCH
}

enum FactStatus {
  NONE             // grey badge — no verification yet
  AI               // blue — AI-verified, no human yet
  VERIFIED         // green single-check
  FULLY            // green double-check
  NEEDS_REVIEW     // amber
  DISPUTED         // red
}

enum VerificationActionType {
  VERIFY
  FLAG
  SUGGEST_UPDATE
}

enum VerificationResolution {
  PENDING
  VALIDATED        // flag was correct / suggestion accepted
  DISMISSED        // flag was wrong
}

enum AuditResult {
  APPROVED
  REJECTED
  CORRECTED
}

enum BadgeLevel {
  NEWCOMER
  CONTRIBUTOR
  VERIFIER
  TRUSTED_VERIFIER
  DOMAIN_EXPERT
}

// ─────────────────────────────────────────────────────────────────────────
// Phase 1.2 — Domain Expert credentials
//
// Users claim affiliation with a recognized institution (IIT, AIIMS,
// UPSC etc.). Verification paths:
//   1. Institutional email (blocked — needs email infra; flow stubbed)
//   2. Community vouching (3 vouches by existing Domain Experts in the
//      same credential domain → auto-promote)
//   3. Admin manual grant (bootstrap path until the first DEs exist)
//
// On verification, the credential gets stamped + the user's badgeLevel
// promotes to DOMAIN_EXPERT (idempotent: if already DOMAIN_EXPERT we
// just append the credential).
//
// User.domainExpertCredentials Json column is the cached read-side
// view. The UserCredential table is the source of truth.
// ─────────────────────────────────────────────────────────────────────────

model UserCredential {
  id            String                  @id @default(cuid())
  userId        String
  // What credential domain this proves (matches CredentialDomain in
  // src/lib/institutional-domains.ts — kept as a free string here so
  // adding a domain in code doesn't require a schema migration).
  domain        String
  // "alumnus", "current_student", "currently_at", "working_at",
  // "exam_cleared" — free text, validated by the form.
  claimType     String
  // Institution display name, e.g., "IIT Madras", "UPSC".
  institution   String
  // Verification status of THIS credential row.
  status        CredentialStatus        @default(PENDING)
  // How it was verified once status flips to VERIFIED.
  verifiedVia   CredentialVerifiedVia?
  // The email used (if verifiedVia = INSTITUTIONAL_EMAIL); blanked
  // post-verification per privacy rule.
  verifiedEmail String?
  verifiedAt    DateTime?
  // Admin who manually granted (if verifiedVia = ADMIN_GRANT) or
  // approved the credential (if applicable). NULL otherwise.
  approvedBy    String?
  // Optional context from the user when claiming (year of graduation,
  // department, etc.) — stays even after verification.
  notes         String?                 @db.Text

  createdAt     DateTime                @default(now())
  updatedAt     DateTime                @updatedAt

  user          User                    @relation("UserCredentials", fields: [userId], references: [id], onDelete: Cascade)
  vouches       CredentialVouch[]

  @@index([userId])
  @@index([status])
  @@index([domain, status])
}

model CredentialVouch {
  id            String   @id @default(cuid())
  credentialId  String
  // Voucher must themselves be a verified DOMAIN_EXPERT in the same
  // domain (enforced in application code; not in schema constraint
  // because the check requires cross-table logic).
  voucherUserId String
  comment       String?  @db.Text
  createdAt     DateTime @default(now())

  credential    UserCredential @relation(fields: [credentialId], references: [id], onDelete: Cascade)
  voucher       User           @relation("UserVouches", fields: [voucherUserId], references: [id], onDelete: Cascade)

  @@unique([credentialId, voucherUserId])
  @@index([credentialId])
  @@index([voucherUserId])
}

enum CredentialStatus {
  PENDING     // claim submitted, awaiting verification path completion
  VERIFIED    // verification path completed — user is now DOMAIN_EXPERT
  REJECTED    // admin rejected the claim
  REVOKED     // previously verified but later revoked (e.g., fraud)
}

enum CredentialVerifiedVia {
  INSTITUTIONAL_EMAIL    // one-time link sent to verified email domain
  COMMUNITY_VOUCHING     // 3+ existing DEs in the same domain vouched
  ADMIN_GRANT            // admin granted manually (bootstrap path)
  DOCUMENT_REVIEW        // admin reviewed an uploaded doc (Phase 1.2.x)
}

// ─────────────────────────────────────────────────────────────────────
// Notification — in-app + email-digest delivery for events that
// concern a specific user. Created by application code (no DB
// triggers) so we control timing + dedup precisely.
//
// Email digest is OFF at platform-level (no email infra yet). The
// `emailedAt` field exists so when Resend/SendGrid lands we can scan
// the table for un-emailed unread rows and batch-send.
// ─────────────────────────────────────────────────────────────────────
model Notification {
  id          String                @id @default(cuid())
  userId      String
  type        NotificationType
  // Headline shown in the bell dropdown + on /me/notifications.
  title       String
  // Optional one-line context (e.g., "JEE Main 2026 application dates").
  body        String?               @db.Text
  // Where clicking the notification takes the user. Relative path.
  link        String?
  // Dedup key — application code passes a stable string so the same
  // event can't create two notifications. Optional.
  dedupKey    String?
  readAt      DateTime?
  emailedAt   DateTime?
  createdAt   DateTime              @default(now())

  user        User                  @relation("UserNotifications", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, dedupKey])
  @@index([userId, readAt])
  @@index([userId, createdAt])
  @@index([emailedAt])
}

enum NotificationType {
  // Verification events
  VERIFICATION_APPROVED      // your verification got APPROVED in audit
  VERIFICATION_REJECTED      // your verification got REJECTED in audit
  VERIFICATION_CORRECTED     // admin corrected your verification

  // Credential events
  CREDENTIAL_VOUCHED         // someone vouched for your credential
  CREDENTIAL_VERIFIED        // your credential got verified (you're now DE!)
  CREDENTIAL_REJECTED        // admin rejected your credential claim

  // Badge / promotion events
  BADGE_PROMOTED             // you got promoted to next badge level

  // Flag follow-up
  FLAG_VALIDATED             // a flag you raised was validated
  SUGGESTION_ACCEPTED        // an update suggestion you submitted was accepted

  // Misc
  ADMIN_MESSAGE              // free-form admin-issued notification
}
